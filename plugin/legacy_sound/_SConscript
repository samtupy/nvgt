Import("env")
scriptarray = env.SharedObject("scriptarray", "#ASAddon/plugin/scriptarray.cpp")
if ARGUMENTS.get("no_shared_plugins", "0") == "0":
	libs = ["PocoFoundation"]
	if env["NVGT_TARGET"] == "windows": libs += ["user32"]
	env.SharedLibrary(env["PLUGIN_DEST_DIR"] + "/legacy_sound", ["pack.cpp", "sound.cpp", scriptarray], LIBS = libs + ["bass", "bass_fx", "bassmix", "phonon"])
static_pack = env.Object("pack_static", "pack.cpp", CPPDEFINES = list(env["CPPDEFINES"]) + [("NVGT_PLUGIN_STATIC", "legacy_sound")])
static_sound = env.Object("sound_static", "sound.cpp", CPPDEFINES = list(env["CPPDEFINES"]) + [("NVGT_PLUGIN_STATIC", "legacy_sound")])
static = env.StaticLibrary("#build/lib/legacy_sound", [static_pack, static_sound])
static = [static, "bass", "bass_fx", "bassmix"]
Return("static")
