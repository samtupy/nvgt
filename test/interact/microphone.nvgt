void main() {
	mixer output;
	microphone mic;
	mic.attach_output_bus(0, output, 0);
	//set_sound_global_hrtf(true);
	//output.set_position_3d(-8, 6, 8);
	show_window("test");
	while (!key_pressed(KEY_ESCAPE)) {
		wait(5);
		string chr = get_characters();
		int n = parse_int(chr);
		if (n == 0) continue;
		screen_reader_speak(mic.set_device(n));
	}
}
