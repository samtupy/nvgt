void main() {
	library l;
	if (!l.load("user32")) {
		alert("error", "can't load library");
		return;
	}
	library_function@ MessageBoxW = l.get("int MessageBoxW(int, wchar*, wchar*, int)");
	var@ d = MessageBoxW(0, "this is a test", "no way this will work", 1);
	alert("test", int(d));
	MessageBoxW(0, "It does?", "Whoa!", 0);
}
