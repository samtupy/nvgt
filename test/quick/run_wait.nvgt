void main() {
	process@ cmd = run({"cmd", "/Q"}, PROCESS_CAPTURE | PROCESS_PIPE_STDIN);
	string output;
	while ((output = cmd.stdout.read()).empty()) wait(10);
	alert("test", output);
	cmd.stdin << "echo this is a test\n";
	while ((output = cmd.stdout.read()).empty()) wait(10);
	alert("test", output);
	cmd.stdin << "exit\n";
	alert(cmd.pid, cmd.wait());
}
